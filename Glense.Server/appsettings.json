{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:50653",
      "http://localhost:50654",
      "http://localhost:3000"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "account-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "profile-route": {
        "ClusterId": "account-cluster",
        "Match": {
          "Path": "/api/profile/{**catch-all}"
        }
      },
      "notification-route": {
        "ClusterId": "account-cluster",
        "Match": {
          "Path": "/api/notification/{**catch-all}"
        }
      },
      "videos-route": {
        "ClusterId": "video-cluster",
        "Match": {
          "Path": "/api/videos/{**catch-all}"
        }
      },
      "subscriptions-route": {
        "ClusterId": "video-cluster",
        "Match": {
          "Path": "/api/subscriptions/{**catch-all}"
        }
      },
      "videolikes-route": {
        "ClusterId": "video-cluster",
        "Match": {
          "Path": "/api/videolikes/{**catch-all}"
        }
      },
      "playlists-route": {
        "ClusterId": "video-cluster",
        "Match": {
          "Path": "/api/playlists/{**catch-all}"
        }
      },
      "playlistvideos-route": {
        "ClusterId": "video-cluster",
        "Match": {
          "Path": "/api/playlistvideos/{**catch-all}"
        }
      },
      "donation-route": {
        "ClusterId": "donation-cluster",
        "Match": {
          "Path": "/api/donation/{**catch-all}"
        }
      },
      "wallet-route": {
        "ClusterId": "donation-cluster",
        "Match": {
          "Path": "/api/wallet/{**catch-all}"
        }
      },
      "chats-route": {
        "ClusterId": "chat-cluster",
        "Match": {
          "Path": "/api/chats/{**catch-all}"
        }
      },
      "messages-route": {
        "ClusterId": "chat-cluster",
        "Match": {
          "Path": "/api/messages/{**catch-all}"
        }
      },
      "signalr-route": {
        "ClusterId": "chat-cluster",
        "Match": {
          "Path": "/hubs/chat/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "account-cluster": {
        "Destinations": {
          "account-service": {
            "Address": "http://localhost:5001"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Path": "/health"
          }
        },
        "HttpRequest": {
          "ActivityTimeout": "00:00:30"
        }
      },
      "video-cluster": {
        "Destinations": {
          "video-service": {
            "Address": "http://localhost:5002"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Path": "/health"
          }
        },
        "HttpRequest": {
          "ActivityTimeout": "00:05:00"
        }
      },
      "donation-cluster": {
        "Destinations": {
          "donation-service": {
            "Address": "http://localhost:5100"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Path": "/health"
          }
        },
        "HttpRequest": {
          "ActivityTimeout": "00:00:30"
        }
      },
      "chat-cluster": {
        "Destinations": {
          "chat-service": {
            "Address": "http://localhost:5004"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Path": "/health"
          }
        },
        "HttpRequest": {
          "ActivityTimeout": "00:00:30"
        }
      }
    }
  }
}
