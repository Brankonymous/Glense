# Glense Microservices Environment Configuration
# Copy this file to .env and modify as needed

# ===========================================
# DATABASE CREDENTIALS
# ===========================================
POSTGRES_USER=glense
POSTGRES_PASSWORD=glense123

# ===========================================
# JWT SETTINGS (must be same across all services)
# ===========================================
JWT_ISSUER=GlenseAccountService
JWT_AUDIENCE=GlenseApp
JWT_SECRET_KEY=YourSuperSecretKeyThatIsAtLeast32CharactersLong!

# ===========================================
# SERVICE PORTS (external)
# ===========================================
ACCOUNT_SERVICE_PORT=5001
VIDEO_SERVICE_PORT=5002
DONATION_SERVICE_PORT=5100
CHAT_SERVICE_PORT=5004
API_GATEWAY_PORT=5050
FRONTEND_PORT=3000

# ===========================================
# DATABASE PORTS (external)
# ===========================================
POSTGRES_ACCOUNT_PORT=5432
POSTGRES_VIDEO_PORT=5433
POSTGRES_DONATION_PORT=5434
POSTGRES_CHAT_PORT=5435
