@@ -0,0 +1,37 @@
+name: Integration Tests
+
+on:
+  push:
+    branches: [main]
+  pull_request:
+    branches: [main]
+
+jobs:
+  integration-tests:
+    runs-on: ubuntu-latest
+
+    steps:
+      - uses: actions/checkout@v4
+
+      - name: Setup .NET
+        uses: actions/setup-dotnet@v4
+        with:
+          dotnet-version: '8.0.x'
+
+      - name: Restore dependencies
+        run: dotnet restore
+
+      - name: Build
+        run: dotnet build --no-restore
+
+      - name: Test AccountService
+        run: dotnet test tests/AccountService.IntegrationTests/AccountService.IntegrationTests.csproj --no-build --verbosity normal
+
+      - name: Test VideoCatalogue
+        run: dotnet test tests/VideoCatalogue.IntegrationTests/VideoCatalogue.IntegrationTests.csproj --no-build --verbosity normal
+
+      - name: Test DonationService
+        run: dotnet test tests/DonationService.IntegrationTests/DonationService.IntegrationTests.csproj --no-build --verbosity normal
+
+      - name: Test ChatService
+        run: dotnet test tests/ChatService.IntegrationTests/ChatService.IntegrationTests.csproj --no-build --verbosity normal
